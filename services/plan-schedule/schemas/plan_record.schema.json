{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "plan_record.schema.json",
  "title": "PlanRecord",
  "description": "Output artifact for Stage 03. One PlanRecord per approved/re-baselined estimate.",
  "type": "object",
  "required": ["plan_id", "demand_id", "end_date", "critical_path_task_ids", "tasks"],
  "additionalProperties": false,
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Unique plan identifier, e.g. PLN-0001-1"
    },
    "demand_id": {
      "type": "string",
      "description": "Demand this plan covers, e.g. DEM-2026-0001"
    },
    "end_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date — last working day of the final task"
    },
    "critical_path_task_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Ordered list of task_ids on the critical path"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "description": "All scheduled tasks in this plan",
      "items": {
        "type": "object",
        "required": ["task_id", "name", "start_date", "end_date", "owner", "predecessor_task_ids"],
        "additionalProperties": false,
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Unique task identifier within this plan"
          },
          "name": {
            "type": "string",
            "description": "Human-readable task name"
          },
          "start_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO 8601 start date"
          },
          "end_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO 8601 end date (inclusive last working day)"
          },
          "owner": {
            "type": "string",
            "description": "Named owner for this task"
          },
          "predecessor_task_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "task_ids that must complete before this task starts"
          }
        }
      }
    }
  }
}
