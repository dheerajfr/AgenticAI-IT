{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "team_config.schema.json",
  "title": "TeamConfig",
  "description": "Team composition and daily capacity configuration.",
  "type": "object",
  "required": ["team_size", "roles"],
  "additionalProperties": false,
  "properties": {
    "team_size": {
      "type": "integer",
      "minimum": 1,
      "description": "Total headcount across all roles"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "description": "Breakdown of the team by role",
      "items": {
        "type": "object",
        "required": ["role", "count", "hours_per_day_per_person"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "type": "string",
            "enum": ["backend", "frontend", "qa", "devops"],
            "description": "Role identifier"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of people in this role"
          },
          "hours_per_day_per_person": {
            "type": "number",
            "minimum": 1,
            "maximum": 24,
            "description": "Available working hours per person per day"
          },
          "members": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional list of named members for round-robin ownership assignment"
          }
        }
      }
    }
  }
}
