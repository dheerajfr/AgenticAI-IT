          "sre-oncall@company.com"
        ]
      },
      {
        "alert_id": "ALT-003",
        "component_id": "svc-auth",
        "component_type": "microservice",
        "name": "svc-auth Latency Violation",
        "condition": "p99_latency > 500ms",
        "severity": "critical",
        "notify": [
